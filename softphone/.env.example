# SIP Connection Settings (Example)
VITE_REMOTE_WS_URL=wss://your-asterisk-domain.com:8089/ws
VITE_REMOTE_EXTENSION=your_extension
VITE_REMOTE_PASSWORD=your_password
VITE_ARI_USER=your_ari_user
VITE_ARI_PASS=your_ari_password
VITE_ARI_URL=http://{baseIp}:8088

# Logging Endpoints
VITE_LOG_URL_LOCAL=http://{baseIp}:5000/log-activity
VITE_LOG_URL_REMOTE=https://{baseIp}/api/log.php

# Log Retrieval Endpoints
VITE_GET_LOGS_URL_LOCAL=http://{baseIp}:5000/get-activities
VITE_GET_LOGS_URL_REMOTE=https://{baseIp}/get_logs.php